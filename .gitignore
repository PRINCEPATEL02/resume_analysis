# ─────────────────────────────────────────────────────
#  HireReady AI — .gitignore
#  Everything below will NOT be uploaded to GitHub
# ─────────────────────────────────────────────────────

# ── Dependencies ──────────────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# ── Environment variables (NEVER commit these!) ───────
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.staging

# ── Build outputs ─────────────────────────────────────
dist/
dist-ssr/
build/
out/
.output/

# ── Vite cache ────────────────────────────────────────
.vite/
vite.config.ts.timestamp-*

# ── TypeScript build info ─────────────────────────────
*.tsbuildinfo
tsconfig.tsbuildinfo

# ── Logs ──────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── OS generated files ────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── IDE / Editor ──────────────────────────────────────
.vscode/settings.json
.vscode/launch.json
.vscode/*.code-workspace
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
*~

# ── Testing ───────────────────────────────────────────
coverage/
.nyc_output/
*.lcov

# ── Package manager locks (keep one, ignore others) ───
# Uncomment the one you DON'T use:
# package-lock.json   # if using yarn/pnpm
# yarn.lock           # if using npm/pnpm
# pnpm-lock.yaml      # if using npm/yarn

# ── Deployment platforms ──────────────────────────────
.vercel/
.netlify/
.railway/

# ── Certificates & keys ───────────────────────────────
*.pem
*.key
*.crt
*.p12
*.pfx

# ── Miscellaneous ─────────────────────────────────────
*.local
.cache/
.temp/
tmp/
temp/
